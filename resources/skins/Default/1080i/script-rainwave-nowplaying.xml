<?xml version="1.0" encoding="UTF-8"?>
<window>
    <!-- This dialog is shown with show(), never doModal(), and has no
         focusable controls, so it floats on top of whatever the user
         is browsing without stealing remote/keyboard input. -->
    <coordinates>
        <system>0</system>
    </coordinates>

    <controls>
        <!-- background slideshow, drawn first so it sits behind
             everything else. Only visible once a folder has actually
             been configured in Add-on Settings > Slideshow;
             service.py clears the property when the feature is off,
             so this stays hidden otherwise. The solid backdrop below
             sits underneath the crossfade: if the two fading
             slides ever dip below 100% combined opacity at the same
             instant, this is what shows through instead of whatever
             sits behind the dialog. -->
        <control type="image">
            <visible>!IsEmpty(Window(10000).Property(Rainwave.SlideshowPath))</visible>
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF000000">white.png</texture>
        </control>

        <!-- Hero art from SteamGridDB is very wide/short relative to
             a 16:9 screen (e.g. 1920x620, ~3.1:1 vs 1.78:1). "scale"
             aspectratio (crop-to-fill) was zooming in and
             cropping the left/right edges off to cover the full
             1920x1080 frame. Each slot is now a group with two
             layers instead of a single image: a cropped, dimmed
             blow-up filling the frame (so there's no empty space),
             behind the same image again at aspectratio="keep" (fully
             visible, letterboxed) on top: the classic "blurred
             backdrop behind a letterboxed picture" look, minus an
             actual blur (Kodi's <image> control has no blur filter
             to reach for here; dimming alone is enough to keep it
             from reading as a second, competing copy of the image).
             The fade animation moves to the group so both layers of
             a slot cross-fade together as one unit. -->
        <control type="group">
            <visible>String.IsEqual(Window(10000).Property(Rainwave.SlideshowActive),A)</visible>
            <animation effect="fade" time="1000">VisibleChange</animation>

            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1920</width>
                <height>1080</height>
                <texture background="true" colordiffuse="70FFFFFF">$INFO[Window(10000).Property(Rainwave.SlideshowImageA)]</texture>
                <aspectratio aligny="center" alignx="center">scale</aspectratio>
            </control>

            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1920</width>
                <height>1080</height>
                <texture background="true">$INFO[Window(10000).Property(Rainwave.SlideshowImageA)]</texture>
                <aspectratio aligny="center" alignx="center">keep</aspectratio>
            </control>
        </control>

        <control type="group">
            <visible>String.IsEqual(Window(10000).Property(Rainwave.SlideshowActive),B)</visible>
            <animation effect="fade" time="1000">VisibleChange</animation>

            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1920</width>
                <height>1080</height>
                <texture background="true" colordiffuse="70FFFFFF">$INFO[Window(10000).Property(Rainwave.SlideshowImageB)]</texture>
                <aspectratio aligny="center" alignx="center">scale</aspectratio>
            </control>

            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1920</width>
                <height>1080</height>
                <texture background="true">$INFO[Window(10000).Property(Rainwave.SlideshowImageB)]</texture>
                <aspectratio aligny="center" alignx="center">keep</aspectratio>
            </control>
        </control>

        <!-- dim overlay so the info panel stays readable on top of the photos -->
        <control type="image">
            <visible>!IsEmpty(Window(10000).Property(Rainwave.SlideshowPath))</visible>
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="80000000">white.png</texture>
        </control>

        <control type="group">
            <posx>60</posx>
            <posy>760</posy>

            <!-- semi-transparent background panel -->
            <control type="image">
                <width>1350</width>
                <height>276</height>
                <texture colordiffuse="C0000000">white.png</texture>
            </control>

            <!-- settings shortcut: opens this addon's settings directly
                 from the playback view. The dialog otherwise forwards
                 all remote/keyboard navigation to the window underneath
                 (see nowplaying_dialog.py) rather than reacting to it
                 itself, so a focusable control here would never
                 actually receive an OK/Select press. Mouse and touch
                 clicks bypass that forwarding entirely and reach
                 controls directly though, so this works for mouse and
                 touch users. Remote/keyboard users get the same action
                 via the context-menu button instead (see onAction() in
                 nowplaying_dialog.py). -->
            <control type="button" id="503">
                <posx>1300</posx>
                <posy>14</posy>
                <width>36</width>
                <height>36</height>
                <texturefocus colordiffuse="FFFFFFFF">settings.png</texturefocus>
                <texturenofocus colordiffuse="A0FFFFFF">settings.png</texturenofocus>
                <onclick>Addon.OpenSettings(plugin.audio.rainwave)</onclick>
                <label></label>
            </control>

            <!-- Everything below is the real now-playing content:
                 hidden for as long as service.py hasn't yet caught
                 the display up with the actual (still-buffering)
                 audio, in favor of the "Tuning in..." placeholder
                 further down. See Rainwave.Buffering in
                 service.py/sync_queue.py: without this, tuning in
                 just looks like the widget failed to load for the
                 first ~15-20 seconds, rather than looking like it's
                 deliberately waiting for something. -->
            <control type="group">
                <visible>!String.IsEqual(Window(10000).Property(Rainwave.Buffering),true)</visible>

            <!-- album art -->
            <control type="image">
                <posx>42</posx>
                <posy>22</posy>
                <width>212</width>
                <height>212</height>
                <texture fallback="icon.png">$INFO[Window(10000).Property(Rainwave.Art)]</texture>
                <aspectratio aligny="center" alignx="center">scale</aspectratio>
            </control>

            <!-- now playing label -->
            <control type="label">
                <posx>270</posx>
                <posy>26</posy>
                <width>1040</width>
                <height>28</height>
                <font>font18</font>
                <textcolor>FFFFC800</textcolor>
                <label>[B]Now playing[/B]</label>
                <scroll>true</scroll>
                <scrollspeed>40</scrollspeed>
            </control>

            <!-- horizontal line -->
            <control type="label">
                <posx>270</posx>
                <posy>34</posy>
                <width>1040</width>
                <height>28</height>
                <font>font18</font>
                <textcolor>FFFFC800</textcolor>
                <label>[B]________________________________________________________________[/B]</label>
                <scroll>false</scroll>
                <scrollspeed>40</scrollspeed>
            </control>

            <!-- track title -->
            <control type="label">
                <posx>270</posx>
                <posy>70</posy>
                <width>1040</width>
                <height>28</height>
                <font>font12_title</font>
                <textcolor>FFFFFFFF</textcolor>
                <label>$INFO[Window(10000).Property(Rainwave.Title)]</label>
                <scroll>true</scroll>
                <scrollspeed>40</scrollspeed>
            </control>

            <!-- artist -->
            <control type="label">
                <posx>270</posx>
                <posy>110</posy>
                <width>1040</width>
                <height>24</height>
                <font>font12</font>
                <textcolor>FFCCCCCC</textcolor>
                <label>$INFO[Window(10000).Property(Rainwave.Artist)]</label>
                <scroll>true</scroll>
                <scrollspeed>40</scrollspeed>
            </control>

            <!-- album -->
            <control type="label">
                <posx>270</posx>
                <posy>140</posy>
                <width>1040</width>
                <height>22</height>
                <font>font10</font>
                <textcolor>FF999999</textcolor>
                <label>$INFO[Window(10000).Property(Rainwave.Album)]</label>
                <scroll>true</scroll>
                <scrollspeed>40</scrollspeed>
            </control>

            <!-- station name -->
            <control type="label">
                <posx>270</posx>
                <posy>170</posy>
                <width>1040</width>
                <height>22</height>
                <font>font10</font>
                <textcolor>FF3FA9F5</textcolor>
                <label>$INFO[Window(10000).Property(Rainwave.Station)]</label>
            </control>

            <!-- playback progress bar -->
            <!-- Driven directly from Python (nowplaying_dialog.py),
                 not $INFO: Rainwave is a live stream, not a seekable
                 file, so Kodi's own Player.Progress infolabel doesn't
                 reflect song position. setPercent()/setLabel() are
                 called on these control IDs once a second instead. -->
            <control type="progress">
                <id>501</id>
                <posx>270</posx>
                <posy>210</posy>
                <width>1040</width>
                <height>20</height>
            </control>

            <!-- elapsed / total time -->
            <control type="label">
                <id>502</id>
                <posx>1310</posx>
                <posy>236</posy>
                <width>1040</width>
                <height>22</height>
                <font>font10</font>
                <textcolor>FFCCCCCC</textcolor>
                <align>right</align>
                <label>0:00 / 0:00</label>
            </control>

            </control>

            <!-- buffering placeholder: see the comment above where
                 the content group opens. Centered in the same card
                 area the real content occupies.

                 font18 is actually a 120pt bold font (see Font.xml),
                 the same one used for the "Now playing" header above,
                 so the label height here is generous on purpose to
                 give it room; a tight height would just clip the
                 text rather than shrink it, since Kodi doesn't
                 auto-scale font size to fit a control. -->
            <control type="group">
                <visible>String.IsEqual(Window(10000).Property(Rainwave.Buffering),true)</visible>

                <!-- spinning "in progress" indicator. Two attempts at
                     a native Kodi <animation effect="rotate"> both
                     failed to render at all, so rather than guess a
                     third time at syntax I can't actually test, this
                     instead reuses the one animation technique
                     already proven to work throughout this addon
                     (the slideshow crossfade, the up-next/previous
                     panel): drive it from Python instead. service.py
                     cycles Rainwave.SpinnerFrame through 12
                     pre-rotated frames (resources/media/spinner_00.png
                     .. spinner_11.png) once every tick while
                     Rainwave.Buffering is set, and this control just
                     displays whichever one is current, the same
                     $INFO-bound-to-a-Python-set-property pattern the
                     album art and background images already use. -->
                <control type="image">
                    <posx>651</posx>
                    <posy>40</posy>
                    <width>48</width>
                    <height>48</height>
                    <texture>$INFO[Window(10000).Property(Rainwave.SpinnerFrame)]</texture>
                </control>

                <control type="label">
                    <posx>0</posx>
                    <posy>100</posy>
                    <width>1350</width>
                    <height>60</height>
                    <font>font18</font>
                    <textcolor>FFFFC800</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <label>[B]Tuning in...[/B]</label>
                </control>

                <!-- underline: a plain color bar rather than an
                     underscore string of text, the same technique
                     as the "up next / previously played" divider
                     further down this file. A text-based line at
                     font18's size rendered far wider than its box and
                     got ellipsis-truncated; a fixed-width image bar
                     doesn't have that problem and is easy to size and
                     position precisely right under the label above. -->
                <control type="image">
                    <posx>575</posx>
                    <posy>158</posy>
                    <width>200</width>
                    <height>3</height>
                    <texture colordiffuse="FFFFC800">white.png</texture>
                </control>

                <control type="label">
                    <posx>0</posx>
                    <posy>184</posy>
                    <width>1350</width>
                    <height>24</height>
                    <font>font10</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <align>center</align>
                    <label>Syncing the display with the stream</label>
                </control>
            </control>

        </control>

        <!-- previous / next panel, sitting to the right of the
             now-playing card at the same height. Split into two equal
             halves by a horizontal divider: "up next" on top,
             "previously played" below; each laid out exactly like a
             smaller now-playing card (artwork left, gold header +
             divider, title, artist) so the same visual language
             repeats at both the panel and row level.
             Rainwave doesn't expose live vote counts for an open
             election (see api.py), so there's no reliable single
             "winner" to show in the top half; instead widget.py
             rotates through every candidate one at a time, advancing
             once per 5-second poll, so all of them get shown in turn
             rather than guessing.
             Hidden entirely when the "Show previous / up next panel"
             setting is off. -->
        <control type="group">
            <visible>String.IsEqual(Window(10000).Property(Rainwave.ShowPrevNext),true)</visible>
            <posx>1430</posx>
            <posy>760</posy>

            <!-- semi-transparent background panel, matching the now-playing card -->
            <control type="image">
                <width>424</width>
                <height>276</height>
                <texture colordiffuse="C0000000">white.png</texture>
            </control>

            <!-- divider splitting "up next" from "previously played" -->
            <control type="image">
                <posx>24</posx>
                <posy>138</posy>
                <width>376</width>
                <height>1</height>
                <texture colordiffuse="FF555555">white.png</texture>
            </control>

            <!-- ===== up next (top half) ===== -->
            <!-- Rainwave doesn't expose live vote counts for an open
                 election (see api.py), so widget.py rotates through
                 every candidate here instead of guessing a winner,
                 swapping which one is shown every 15 seconds. Same
                 double-buffered A/B slot + fade technique as the
                 picture slideshow above: two overlapping copies of
                 this row, each bound to one slot, with the inactive
                 one always pre-populated before the swap so the fade
                 crossfades between two fully-loaded candidates rather
                 than popping through a blank state. -->

            <control type="group">
                <visible>String.IsEqual(Window(10000).Property(Rainwave.NextActive),A)</visible>
                <animation effect="fade" time="600">VisibleChange</animation>

                <control type="image">
                    <posx>12</posx>
                    <posy>12</posy>
                    <width>106</width>
                    <height>106</height>
                    <texture fallback="icon.png">$INFO[Window(10000).Property(Rainwave.NextArtA)]</texture>
                    <aspectratio aligny="center" alignx="center">scale</aspectratio>
                </control>

                <control type="label">
                    <posx>130</posx>
                    <posy>56</posy>
                    <width>282</width>
                    <height>24</height>
                    <font>font12</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <label>$INFO[Window(10000).Property(Rainwave.NextTitleA)]</label>
                    <scroll>true</scroll>
                    <scrollspeed>40</scrollspeed>
                </control>

                <control type="label">
                    <posx>130</posx>
                    <posy>88</posy>
                    <width>282</width>
                    <height>22</height>
                    <font>font10</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Window(10000).Property(Rainwave.NextArtistA)]</label>
                    <scroll>true</scroll>
                    <scrollspeed>40</scrollspeed>
                </control>
            </control>

            <control type="group">
                <visible>String.IsEqual(Window(10000).Property(Rainwave.NextActive),B)</visible>
                <animation effect="fade" time="600">VisibleChange</animation>

                <control type="image">
                    <posx>12</posx>
                    <posy>12</posy>
                    <width>106</width>
                    <height>106</height>
                    <texture fallback="icon.png">$INFO[Window(10000).Property(Rainwave.NextArtB)]</texture>
                    <aspectratio aligny="center" alignx="center">scale</aspectratio>
                </control>

                <control type="label">
                    <posx>130</posx>
                    <posy>56</posy>
                    <width>282</width>
                    <height>24</height>
                    <font>font12</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <label>$INFO[Window(10000).Property(Rainwave.NextTitleB)]</label>
                    <scroll>true</scroll>
                    <scrollspeed>40</scrollspeed>
                </control>

                <control type="label">
                    <posx>130</posx>
                    <posy>88</posy>
                    <width>282</width>
                    <height>22</height>
                    <font>font10</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Window(10000).Property(Rainwave.NextArtistB)]</label>
                    <scroll>true</scroll>
                    <scrollspeed>40</scrollspeed>
                </control>
            </control>

            <control type="label">
                <posx>130</posx>
                <posy>16</posy>
                <width>282</width>
                <height>22</height>
                <font>font10</font>
                <textcolor>FFFFC800</textcolor>
                <label>[B]Coming up[/B]</label>
            </control>

            <control type="label">
                <posx>130</posx>
                <posy>24</posy>
                <width>282</width>
                <height>22</height>
                <font>font10</font>
                <textcolor>FFFFC800</textcolor>
                <label>[B]_________________[/B]</label>
            </control>

            <!-- ===== previously played (bottom half) ===== -->

            <control type="image">
                <posx>12</posx>
                <posy>158</posy>
                <width>106</width>
                <height>106</height>
                <texture fallback="icon.png">$INFO[Window(10000).Property(Rainwave.PreviousArt)]</texture>
                <aspectratio aligny="center" alignx="center">scale</aspectratio>
            </control>

            <control type="label">
                <posx>130</posx>
                <posy>162</posy>
                <width>282</width>
                <height>22</height>
                <font>font10</font>
                <textcolor>FFFFC800</textcolor>
                <label>[B]Previously played[/B]</label>
            </control>

            <control type="label">
                <posx>130</posx>
                <posy>170</posy>
                <width>282</width>
                <height>22</height>
                <font>font10</font>
                <textcolor>FFFFC800</textcolor>
                <label>[B]_________________[/B]</label>
            </control>

            <control type="label">
                <posx>130</posx>
                <posy>202</posy>
                <width>282</width>
                <height>24</height>
                <font>font12</font>
                <textcolor>FFFFFFFF</textcolor>
                <label>$INFO[Window(10000).Property(Rainwave.PreviousTitle)]</label>
                <scroll>true</scroll>
                <scrollspeed>40</scrollspeed>
            </control>

            <control type="label">
                <posx>130</posx>
                <posy>228</posy>
                <width>282</width>
                <height>22</height>
                <font>font10</font>
                <textcolor>FFCCCCCC</textcolor>
                <label>$INFO[Window(10000).Property(Rainwave.PreviousArtist)]</label>
                <scroll>true</scroll>
                <scrollspeed>40</scrollspeed>
            </control>
        </control>
    </controls>
</window>
